<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Abdul Hadi Komail</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;}
  :root{--primary:#1a3a5c;--accent:#2e86ab;--gold:#c9a84c;--light:#f5f7fa;--text:#2d2d2d;--muted:#6b7280;--border:#e2e8f0;--white:#fff;}
  body{font-family:'Segoe UI',system-ui,sans-serif;color:var(--text);background:var(--light);line-height:1.7;}
  nav{position:fixed;top:0;left:0;right:0;background:var(--white);border-bottom:1px solid var(--border);z-index:1000;padding:0 1.5rem;}
  .nav-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:58px;}
  .nav-logo{font-weight:700;font-size:1rem;color:var(--primary);cursor:pointer;letter-spacing:.5px;}
  .nav-links{display:flex;gap:.15rem;flex-wrap:wrap;}
  .nav-links button{background:none;border:none;padding:.35rem .6rem;font-size:.76rem;color:var(--muted);cursor:pointer;border-radius:6px;transition:all .2s;font-family:inherit;}
  .nav-links button:hover,.nav-links button.active{background:var(--primary);color:var(--white);}
  .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px;}
  .hamburger span{display:block;width:22px;height:2px;background:var(--primary);border-radius:2px;}
  .page{display:none;min-height:100vh;padding:78px 2rem 3rem;max-width:1100px;margin:0 auto;}
  .page.active{display:block;}
  .hero{display:flex;align-items:center;gap:3rem;padding:2.5rem 0 2rem;}
  .avatar{width:140px;height:190px;border-radius:16px;overflow:hidden;flex-shrink:0;border:1.5px solid var(--gold);background:var(--light);}
  .avatar img{width:100%;height:100%;object-fit:cover;object-position:center top;}
  .hero-text h1{font-size:2rem;color:var(--primary);font-weight:700;}
  .hero-text h2{font-size:1rem;color:var(--accent);font-weight:400;margin:.3rem 0 .8rem;}
  .hero-text p{color:var(--muted);max-width:540px;font-size:.93rem;}
  .quick-links{display:flex;gap:.8rem;margin-top:1.1rem;flex-wrap:wrap;}
  .btn{padding:.48rem 1.1rem;border-radius:8px;border:none;cursor:pointer;font-size:.86rem;font-family:inherit;transition:all .2s;}
  .btn-primary{background:var(--primary);color:white;}
  .btn-primary:hover{background:var(--accent);}
  .btn-outline{background:none;border:1.5px solid var(--primary);color:var(--primary);}
  .btn-outline:hover{background:var(--primary);color:white;}
  .section-title{font-size:1.35rem;color:var(--primary);font-weight:700;margin-bottom:1.3rem;padding-bottom:.5rem;border-bottom:2px solid var(--gold);display:inline-block;}
  .card{background:var(--white);border-radius:12px;padding:1.4rem;margin-bottom:1rem;border:1px solid var(--border);transition:box-shadow .2s;}
  .card:hover{box-shadow:0 4px 18px rgba(0,0,0,.07);}
  .card h3{color:var(--primary);font-size:.98rem;margin-bottom:.25rem;}
  .card .meta{font-size:.82rem;color:var(--gold);font-weight:600;margin-bottom:.4rem;}
  .card p{color:var(--muted);font-size:.9rem;}
  .tags{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.7rem;}
  .tag{background:var(--light);border:1px solid var(--border);border-radius:20px;padding:.2rem .7rem;font-size:.76rem;color:var(--primary);}
  .tag.accent{background:#e8f4f8;border-color:#b8dde8;color:var(--accent);}
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
  .glance-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-top:1rem;}
  .skill-item{margin-bottom:.9rem;}
  .skill-label{display:flex;justify-content:space-between;font-size:.86rem;margin-bottom:.25rem;color:var(--text);}
  .skill-bar{background:var(--border);border-radius:10px;height:7px;overflow:hidden;}
  .skill-fill{height:100%;border-radius:10px;background:#c9a84c;}
  .contact-info .item{display:flex;align-items:center;gap:.8rem;padding:.65rem 0;border-bottom:1px solid var(--border);}
  .contact-info .item:last-child{border-bottom:none;}
  .ico{width:34px;height:34px;border-radius:8px;background:var(--light);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .badge{display:inline-block;background:#fef3c7;color:#92400e;border:1px solid #fde68a;border-radius:6px;padding:.12rem .55rem;font-size:.73rem;margin-left:.4rem;}
  .insight-split{display:grid;grid-template-columns:1fr 1fr;gap:1.3rem;margin-bottom:1.5rem;}
  .insight-block{background:var(--white);border-radius:12px;padding:1.4rem;border:1px solid var(--border);}
  .insight-block h3{color:var(--primary);font-size:.95rem;font-weight:700;margin-bottom:.8rem;}
  .expr-card{background:var(--white);border-radius:12px;padding:1.4rem;border:1px solid var(--border);margin-bottom:1rem;}
  .expr-card>h3{color:var(--primary);font-weight:700;margin-bottom:.8rem;display:flex;align-items:center;gap:.6rem;}
  .expr-card .card h3{color:var(--primary);font-size:.88rem;margin-bottom:.25rem;text-align:center;display:block;}
  .expr-card .card p{color:var(--muted);font-size:.78rem;text-align:center;}
  .hobby-item{background:var(--white);border-radius:12px;padding:1.1rem 1.4rem;border:1px solid var(--border);display:flex;align-items:center;gap:1.2rem;margin-bottom:.8rem;}
  .hobby-icon{flex-shrink:0;display:flex;align-items:center;justify-content:center;width:48px;}
  .comp-grid{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:.5rem;}
  .comp-tag{background:var(--white);border:1.5px solid var(--border);border-radius:10px;padding:.45rem 1rem;font-size:.83rem;color:var(--primary);font-weight:500;}
  .proj-card{background:var(--white);border-radius:12px;padding:1.4rem;margin-bottom:1rem;border:1px solid var(--border);cursor:pointer;transition:box-shadow .2s;}
  .proj-card:hover{box-shadow:0 4px 18px rgba(0,0,0,.07);}
  .proj-header{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;}
  .proj-header h3{color:var(--primary);font-size:.98rem;margin-bottom:.25rem;}
  .proj-header .meta{font-size:.82rem;color:var(--gold);font-weight:600;margin-bottom:.4rem;}
  .proj-arrow{font-size:1.1rem;color:var(--accent);flex-shrink:0;margin-top:.2rem;}
  .proj-body{display:none;margin-top:1rem;border-top:1px solid var(--border);padding-top:1rem;}
  .proj-body p{font-size:.88rem;color:var(--muted);margin-bottom:.7rem;}
  .proj-body .kw{font-size:.82rem;color:var(--accent);}
  .cert-link{display:inline-block;margin-top:.7rem;font-size:.8rem;color:var(--accent);text-decoration:none;}
  .cert-link:hover{color:var(--primary);}
  .lang-switcher{position:fixed;bottom:0;left:0;right:0;background:var(--white);border-top:1px solid var(--border);z-index:999;display:flex;justify-content:center;gap:.5rem;padding:.6rem 1rem;}
  .lang-btn{background:none;border:1.5px solid var(--border);border-radius:20px;padding:.3rem .9rem;font-size:.78rem;color:var(--muted);cursor:pointer;font-family:inherit;transition:all .2s;}
  .lang-btn:hover{border-color:var(--primary);color:var(--primary);}
  .lang-btn.active{background:var(--primary);color:white;border-color:var(--primary);}
  .page{padding-bottom:4rem;}
  @media(max-width:1024px){.grid-3,.glance-grid{grid-template-columns:1fr 1fr;}}
  @media(max-width:768px){
    .page{padding:70px 1.2rem 4rem;}
    .hero{flex-direction:column;text-align:center;gap:1.5rem;}
    .hero-text h1{font-size:1.6rem;}
    .quick-links{justify-content:center;}
    .grid-2,.grid-3,.insight-split,.glance-grid{grid-template-columns:1fr;}
    .nav-links{display:none;flex-direction:column;position:absolute;top:58px;left:0;right:0;background:white;border-bottom:1px solid var(--border);padding:.8rem 1rem;}
    .nav-links.open{display:flex;}
    .hamburger{display:flex;}
    .section-title{font-size:1.15rem;}
  }
  @media(max-width:480px){
    .page{padding:68px 1rem 4rem;}
    .hero-text h1{font-size:1.4rem;}
    .avatar{width:110px;height:150px;}
    .glance-grid{grid-template-columns:1fr 1fr !important;}
  }
</style>
</head>
