<script>
const pages=['home','insight','expression','education','experience','certificates','awards','skills','projects','hobbies','contact'];

function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-links button').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const i=pages.indexOf(id);
  if(i>=0) document.querySelectorAll('.nav-links button')[i].classList.add('active');
  document.getElementById('navLinks').classList.remove('open');
  window.scrollTo(0,0);
}
function toggleMenu(){document.getElementById('navLinks').classList.toggle('open');}
function toggleAbstract(id){
  const body=document.getElementById(id);
  const arrow=document.getElementById(id+'-arrow');
  const open=body.style.display==='block';
  body.style.display=open?'none':'block';
  arrow.textContent=open?'▼':'▲';
}
function switchTab(tab){
  ['research','calligraphy','design'].forEach(t=>{
    document.getElementById('tab-content-'+t).style.display=t===tab?'block':'none';
    document.getElementById('tab-'+t).className='btn '+(t===tab?'btn-primary':'btn-outline');
  });
  if(tab==='calligraphy') loadGallery('calligraphy');
  if(tab==='design') loadGallery('design');
}
function openLightbox(src){
  const lb=document.getElementById('lightbox');
  document.getElementById('lightbox-img').src=src;
  lb.style.display='flex';
}
function closeLightbox(){document.getElementById('lightbox').style.display='none';}
const galleryLoaded={calligraphy:false,design:false};
const galleryConfig={
  calligraphy:{folder:'calligraphy',galleryId:'calli-gallery',loadingId:'calli-loading'},
  design:{folder:'logos',galleryId:'design-gallery',loadingId:'design-loading'}
};
function loadGallery(type){
  if(galleryLoaded[type]) return;
  galleryLoaded[type]=true;
  const cfg=galleryConfig[type];
  fetch(`https://api.github.com/repos/mngol-01/portfolio/contents/${cfg.folder}`)
    .then(r=>r.json())
    .then(files=>{
      const gallery=document.getElementById(cfg.galleryId);
      const loading=document.getElementById(cfg.loadingId);
      const imgs=files.filter(f=>/\.(jpg|jpeg|png|gif|webp)$/i.test(f.name));
      if(!imgs.length){loading.style.display='none';return;}
      loading.style.display='none';
      imgs.forEach(f=>{
        const rawUrl=`https://raw.githubusercontent.com/mngol-01/portfolio/main/${cfg.folder}/${f.name}`;
        const wrap=document.createElement('div');
        wrap.style.cssText='break-inside:avoid;margin-bottom:1rem;cursor:pointer;';
        wrap.onclick=()=>openLightbox(rawUrl);
        const img=document.createElement('img');
        img.src=rawUrl;img.loading='lazy';
        img.style.cssText='width:100%;border-radius:10px;border:1px solid var(--border);display:block;';
        img.onerror=()=>wrap.remove();
        wrap.appendChild(img);
        gallery.appendChild(wrap);
      });
    })
    .catch(()=>{document.getElementById(cfg.loadingId).style.display='none';});
}

